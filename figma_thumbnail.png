13.856v11.692L17.751 12z"></path></svg></span></span></button></div></div></li><li><img src="data:image/png;base64," alt="Type on a path shown in purple and teal against a pink background" class="fig-1y6dwnd" width="656" height="816" data-lqip="true"/><img data-loading="true" class="fig-3mjy2z" width="656" height="816" loading="lazy" alt="Type on a path shown in purple and teal against a pink background" src="https://cdn.sanity.io/images/599r6htc/regionalized/a43092a3987b43555ead7b8bba779647c4f28fc1-656x816.png?w=656&amp;h=816&amp;q=75&amp;fit=max&amp;auto=format" srcSet="https://cdn.sanity.io/images/599r6htc/regionalized/a43092a3987b43555ead7b8bba779647c4f28fc1-656x816.png?q=75&amp;fit=max&amp;auto=format&amp;dpr=0.5 328w, https://cdn.sanity.io/images/599r6htc/regionalized/a43092a3987b43555ead7b8bba779647c4f28fc1-656x816.png?q=75&amp;fit=max&amp;auto=format&amp;dpr=0.75 492w, https://cdn.sanity.io/images/599r6htc/regionalized/a43092a3987b43555ead7b8bba779647c4f28fc1-656x816.png?q=75&amp;fit=max&amp;auto=format&amp;dpr=2 656w"/></li><li><div class="fig-1t3fry2"><!--$--><!--/$--><div class="fig-9vflm"><button type="button" aria-label="play" class="fig-nk90sr"><span class="btn-inner"><span class="btn-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6.375 20.01V3.99L20.25 12zm1.25-13.856v11.692L17.751 12z"></path></svg></span></span></button></div></div></li><li><img src="data:image/png;base64," alt="A prompt node and a pre-selected image node connect to create the visual output of a butterfly on the Figma Weave interface" class="fig-1y6dwnd" width="656" height="816" data-lqip="true"/><img data-loading="true" class="fig-3mjy2z" width="656" height="816" loading="lazy" alt="A prompt node and a pre-selected image node connect to create the visual output of a butterfly on the Figma Weave interface" src="https://cdn.sanity.io/images/599r6htc/regionalized/b87135e6a9c3ac94f0a433889659b3434086682e-656x816.png?w=656&amp;h=816&amp;q=75&amp;fit=max&amp;auto=format" srcSet="https://cdn.sanity.io/images/599r6htc/regionalized/b87135e6a9c3ac94f0a433889659b3434086682e-656x816.png?q=75&amp;fit=max&amp;auto=format&amp;dpr=0.5 328w, https://cdn.sanity.io/images/599r6htc/regionalized/b87135e6a9c3ac94f0a433889659b3434086682e-656x816.png?q=75&amp;fit=max&amp;auto=format&amp;dpr=0.75 492w, https://cdn.sanity.io/images/599r6htc/regionalized/b87135e6a9c3ac94f0a433889659b3434086682e-656x816.png?q=75&amp;fit=max&amp;auto=format&amp;dpr=2 656w"/></li><li><div class="fig-1t3fry2"><!--$--><!--/$--><div class="fig-9vflm"><button type="button" aria-label="play" class="fig-nk90sr"><span class="btn-inner"><span class="btn-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6.375 20.01V3.99L20.25 12zm1.25-13.856v11.692L17.751 12z"></path></svg></span></span></button></div></div></li><li><img src="data:image/png;base64," alt="UI over a butterfly bitmap mosaic with optionality to change the spacing and establish minimum and maximum sizes" class="fig-1y6dwnd" width="992" height="1232" data-lqip="true"/><img data-loading="true" class="fig-3mjy2z" width="992" height="1232" loading="lazy" alt="UI over a butterfly bitmap mosaic with optionality to change the spacing and establish minimum and maximum sizes" src="https://cdn.sanity.io/images/599r6htc/regionalized/55e1130298788b5d059c311fcc01437142024bd5-992x1232.png?w=992&amp;h=1232&amp;q=75&amp;fit=max&amp;auto=format" srcSet="https://cdn.sanity.io/images/599r6htc/regionalized/55e1130298788b5d059c311fcc01437142024bd5-992x1232.png?q=75&amp;fit=max&amp;auto=format&amp;dpr=0.5 496w, https://cdn.sanity.io/images/599r6htc/regionalized/55e1130298788b5d059c311fcc01437142024bd5-992x1232.png?q=75&amp;fit=max&amp;auto=format&amp;dpr=0.75 744w, https://cdn.sanity.io/images/599r6htc/regionalized/55e1130298788b5d059c311fcc01437142024bd5-992x1232.png?q=75&amp;fit=max&amp;auto=format&amp;dpr=2 992w"/></li></ul></section><section aria-labelledby="_R_8klubsodqivb_" class="fig-1dzlqeg"><div class="fig-1dhjdis"><div class="fig-0"><div class="fig-15n6piu"><div class="fig-1u8qly9"><h2 id="_R_8klubsodqivb_" class="fig-174492g">Start with design context. Build with consistency.<!-- --> </h2><p class="fig-16y2kav"><span class="fig-yn7ivl">Your context, codebase, and agents stay connected so what you design is what gets shipped.</span></p></div></div></div><div class="fig-1ieysyk"><div class="fig-0"><div class="fig-jkja70"><div class="fig-1wmyqx0"><!--$--><!--/$--><div class="fig-9vflm"><button type="button" aria-label="play" class="fig-nk90sr"><span class="btn-inner"><span class="btn-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6.375 20.01V3.99L20.25 12zm1.25-13.856v11.692L17.751 12z"></path></svg></span></span></button></div></div></div></div><div class="fig-5aaeth"><div class="fig-13wylk3"><div class="fig-1u8qly9"></div></div><div class="fig-13f79i2"><div class="fig-1kgzx9z"><a class="fig-1siyav2" href="https://www.figma.com/make/"><span class="btn-inner fig-1qhfzz9"><span class="btn-text fig-1v6pe89">Explore Figma Make</span><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" aria-hidden="true" class="btn-builtin-icon fig-q1jie6"><path fill="currentColor" stroke="currentColor" stroke-width="0.13" d="m12.57 4.205 7.477 7.75.043.045-.043.045-7.478 7.75-.046.047-.046-.045-.734-.71-.046-.044.045-.047 6.195-6.42H3.935v-1.151h14.003l-6.196-6.421-.045-.047.046-.045.734-.709.046-.045z"></path></svg></span></a></div></div></div></div></div></section><section aria-labelledby="_R_aklubsodqivb_" class="fig-1dzlqeg"><div class="fig-1dhjdis"><div class="fig-j7qwjs"><div class="fig-wlhotc"><div class="fig-1u8qly9"><h2 id="_R_aklubsodqivb_" class="fig-xakii4">The products you love are designed in Figma<!-- --> </h2></div></div><div class="fig-9lflse"><div class="fig-kxgf8o"><figure class="fig-jjzheu"><blockquote class="fig-11kcihn"><p>Everyone is able to influence, inspire, and give input without ever leaving the design file. That creates a really transparent, open, and honest process throughout the whole project.</p></blockquote><div class="fig-1cbxyr9"><figcaption class="fig-1bfynk4"><div class="fig-1n9athi"><div aria-hidden="true" class="fig-51j1vz"></div><img src="data:image/jpeg;base64," alt="headshot of Francisco" class="fig-n9qayz" width="48" height="48" data-lqip="true"/><img data-loading="true" aria-hidden="true" class="fig-l7bv62" width="48" height="48" loading="lazy" alt="headshot of Francisco" src="https://cdn.sanity.io/images/599r6htc/regionalized/e4a6dd16868d021fe75ff5cdc4e920e422471a2f-876x876.jpg?w=48&amp;h=48&amp;q=75&amp;fit=max&amp;auto=format" srcSet="https://cdn.sanity.io/images/599r6htc/regionalized/e4a6dd16868d021fe75ff5cdc4e920e422471a2f-876x876.jpg?w=48&amp;q=75&amp;fit=max&amp;auto=format&amp;dpr=0.5 24w, https://cdn.sanity.io/images/599r6htc/regionalized/e4a6dd16868d021fe75ff5cdc4e920e422471a2f-876x876.jpg?w=48&amp;q=75&amp;fit=max&amp;auto=format&amp;dpr=0.75 36w, https://cdn.sanity.io/images/599r6htc/regionalized/e4a6dd16868d021fe75ff5cdc4e920e422471a2f-876x876.jpg?w=48&amp;q=75&amp;fit=max&amp;auto=format 48w, https://cdn.sanity.io/images/599r6htc/regionalized/e4a6dd16868d021fe75ff5cdc4e920e422471a2f-876x876.jpg?w=48&amp;q=75&amp;fit=max&amp;auto=format&amp;dpr=1.5 72w, https://cdn.sanity.io/images/599r6htc/regionalized/e4a6dd16868d021fe75ff5cdc4e920e422471a2f-876x876.jpg?w=48&amp;q=75&amp;fit=max&amp;auto=format&amp;dpr=2 96w"/></div><div><cite class="fig-1s592rj"><span class="fig-gb8ju7">Francisco Seiz</span></cite><p class="fig-b35j3l">Senior Design Director, Code and Theory</p></div></figcaption></div></figure><div><ul role="list" class="fig-cnlbcu"><li class="fig-1vdrh3h"><span class="fig-zjnfh9"><span cl